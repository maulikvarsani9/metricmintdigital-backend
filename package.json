{
  "name": "metricmintdigital-backend",
  "version": "1.0.0",
  "description": "Metricmint Digital Backend API - Blog Management",
  "main": "dist/app.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/app.js",
    "dev": "ts-node-dev --respawn --transpile-only src/app.ts",
    "test": "jest",
